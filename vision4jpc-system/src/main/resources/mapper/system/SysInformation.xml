<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.vision4jpc.system.mapper.SysInformationMapper">

    <!-- 对象映射-VO -->
    <resultMap id="SysInformationVoResult" type="com.vision4jpc.system.entity.vo.SysInformationVo">
        <id property="informationId" column="information_id"/>
        <result property="content" column="content"/>
        <result property="ifReadAlready" column="if_read_already"/>
        <result property="typeName" column="name"/>
        <result property="solution" column="solution"/>
        <result property="createdTime" column="created_time"/>
    </resultMap>

    <!-- 基础查询异常信息VO-SQL -->
    <sql id="selectBaseSysInformation">
        select si.information_id,
               si.content,
               si.if_read_already,
               si.created_time,
               sit.name,
               sit.solution
        from sys_information si
    </sql>

    <!-- 查询所有系统异常信息 -->
    <select id="selectAllSysInformation" resultMap="SysInformationVoResult">
        <include refid="selectBaseSysInformation"/>
        left join sys_information_type sit
        on si.type_status_code = sit.status_code
    </select>

    <!-- 指定ID查询系统异常信息 -->
    <select id="selectSysInformationByID" resultMap="SysInformationVoResult">
        <include refid="selectBaseSysInformation"/>
        left join sys_information_type sit
        on si.type_status_code = sit.status_code
        WHERE si.information_id = #{informationId}
    </select>

    <!-- 插入系统异常信息 -->
    <insert id="insertSysInformation" parameterType="SysInformation">
        insert into sys_information (
        <if test="content != null and content != ''">content,</if>
        <if test="typeStatusCode != null and typeStatusCode != ''">type_status_code,</if>
        <if test="ifReadAlready != null and ifReadAlready != ''">if_read_already,</if>
        -- 假如未指定ifReadAlready默认为1(未读)
        <if test="ifReadAlready == null or ifReadAlready == ''">if_read_already,</if>
        created_time
        )
        values (
        <if test="content != null and content != ''">#{content},</if>
        <if test="typeStatusCode != null and typeStatusCode != ''">#{typeStatusCode},</if>
        <if test="ifReadAlready != null and ifReadAlready != ''">#{ifReadAlready},</if>
        <if test="ifReadAlready == null or ifReadAlready == ''">1,</if>
        sysdate()
        )
    </insert>

    <!-- 更新系统异常信息 -->
    <update id="updateSysInformation" parameterType="SysInformation">
        update sys_information
        <set>
            <if test="content != null">content = #{content},</if>
            <if test="typeStatusCode != null">type_status_code = #{typeStatusCode},</if>
            <if test="ifReadAlready != null">if_read_already = #{ifReadAlready},</if>
            updated_time =sysdate()
        </set>
        where information_id = #{informationId}
    </update>

    <!-- 全部已读 -->
    <update id="updateAllToRead">
        update sys_information
        set if_read_already = '2',
            updated_time = sysdate()
    </update>

    <!-- 删除系统异常信息 -->
    <delete id="deleteSysInformation">
        delete from sys_information where information_id = #{informationId}
    </delete>
</mapper>